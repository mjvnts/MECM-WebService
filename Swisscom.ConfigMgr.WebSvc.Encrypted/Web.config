<?xml version="1.0" encoding="utf-8"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  https://go.microsoft.com/fwlink/?LinkId=301879
  -->
<configuration>
	<configSections>
		<section name="sccmWebSvc" type="Swisscom.ConfigMgr.WebSvc.Encrypted.Config.SccmWebSvcConfig, Swisscom.ConfigMgr.WebSvc.Encrypted" />
	</configSections>
	<connectionStrings>
		<add name="DapDwhConnection" connectionString="" providerName="System.Data.OleDb" />
	</connectionStrings>
	<appSettings />
	<sccmWebSvc>
		<osDeployments>
			<add identifier="ITBS" collectionName="Windows 10 - ITBS" />
			<add identifier="ED" collectionName="Windows 10 - ITBS" />
		</osDeployments>
		<siteServerSettings serverName="sclab-sccm01" siteCode="LAB" domainShortName="BS" useIntune="true" appDisplayName="ConfigMgr.WebSvc" appId="8456bfc2-b7b2-4747-b01b-458e08e2ca79" tenantId="ec182dd5-0237-49e4-b3d6-cf9cbdf149d0" graphUrl="https://graph.microsoft.com/v1.0/" secretString="" />
		<logSettings logFile="C:\temp\Swisscom.ConfigMgr.WebSvc.Encrypted.log" logLevel="0" maxLogFileSize="10240" maxLogFiles="3" temporaryUserFilePath="c:\temp\DisabledUsers" primaryUserVariable="SCS_PrimaryUsers" />
		<securitySettings encryptionKey="" encryptionSalt="" requireEncryption="false" timestampToleranceSeconds="30"/>
		<softwareDeploymentSettings swAdGroupNamePrefix="G_SCCM_" />
	</sccmWebSvc>
	<!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.6.1" />
      </system.Web>
  -->
	<system.web>
		<compilation debug="true" targetFramework="4.7.2" />
		<httpRuntime targetFramework="4.6.1" maxRequestLength="2147483647" />

		<webServices>
			<soapExtensionTypes>
				<add type="Swisscom.ConfigMgr.WebSvc.Encrypted.Security.TransportSecurityExtension, Swisscom.ConfigMgr.WebSvc.Encrypted" priority="1"/>
				<add type="Swisscom.ConfigMgr.WebSvc.Encrypted.Security.TimestampValidationExtension, Swisscom.ConfigMgr.WebSvc.Encrypted" priority="2"/>
			</soapExtensionTypes>
			<protocols>
				<add name="HttpSoap"/>
				<add name="HttpPost"/>
				<add name="HttpGet"/>
				<remove name="HttpSoap12"/> <!-- Disable SOAP 1.2 -->
			</protocols>
		</webServices>
	</system.web>

	<system.webServer>
		<security>
			<requestFiltering>
				<requestLimits maxAllowedContentLength="2147483647" />
			</requestFiltering>
		</security>
		<handlers>
			<remove name="ExtensionlessUrlHandler-Integrated-4.0" />
			<remove name="OPTIONSVerbHandler" />
			<remove name="TRACEVerbHandler" />
			<!-- Add ASMX Handler -->
			<add name="asmx"
				 path="*.asmx"
				 verb="*"
				 type="System.Web.Services.Protocols.WebServiceHandlerFactory"
				 resourceType="Unspecified"
				 preCondition="integratedMode" />
			<add name="ExtensionlessUrlHandler-Integrated-4.0"
				 path="*."
				 verb="*"
				 type="System.Web.Handlers.TransferRequestHandler"
				 preCondition="integratedMode,runtimeVersionv4.0" />
		</handlers>
	</system.webServer>

	<!-- All runtime/assemblyBinding entries -->
	<runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
	<dependentAssembly>
		<assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
